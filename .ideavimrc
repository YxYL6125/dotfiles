" ============================================================================
" IdeaVim Configuration
" ============================================================================
" 文档参考: https://jb.gg/h38q75
" 更多示例: https://jb.gg/share-ideavimrc

" ============================================================================
" 1. 核心编辑器设置 (Core Settings)
" ============================================================================
set scrolloff=5         " 光标上下保留5行，保持上下文可见
set incsearch           " 开启增量搜索，输入时即时高亮
set hlsearch            " 高亮所有搜索匹配项
set ignorecase          " 搜索忽略大小写
set smartcase           " 若搜索包含大写，则切换为大小写敏感
set nu                  " 显示行号
set relativenumber      " 显示相对行号 (方便 5j/10k 跳转)
set clipboard+=unnamed  " 【重要】与系统剪贴板互通 (支持 macOS 复制粘贴)

" 输入法自动切换 (实验性)
set keep-english-in-normal

" ============================================================================
" 2. 插件管理 (Plugins)
" ============================================================================
" 开启 IdeaVim 扩展支持
set extensions

" 启用内置移植的 Vim 插件
set surround            " 环绕字符编辑 (cs"', ds(, ysiw] 等)
set commentary          " 快速注释 (gcc, gc)
set highlightedyank     " 高亮复制的文本 (视觉反馈)

" 以下 Plug 命令仅作记录/兼容 vim-plug 语法，实际由 set 指令激活
Plug 'easymotion/vim-easymotion'
Plug 'tpope/vim-commentary'
Plug 'machakann/vim-highlightedyank'

" ============================================================================
" 3. 基础键位映射 (Basic Mappings)
" ============================================================================
" 设置全局 Leader 键
let mapleader = ','

" 极速退出插入模式
inoremap jk <ESC>
inoremap kj <ESC>

" 修复 Y 的行为 (使其符合 D 和 C 的逻辑，复制到行尾)
nnoremap Y y$

" Q 键映射为格式化代码 (原为进入 Ex 模式)
nnoremap Q gq

" 缩进后保持选中状态 (方便连续缩进)
vnoremap < <gv
vnoremap > >gv

" 快速注释 (利用 commentary 插件)
nmap <Leader>c gcc

" ============================================================================
" 3.5. 黑洞寄存器映射 (Blackhole Register Mappings)
" ============================================================================
" 激进方案: 让删除操作默认使用黑洞寄存器，不影响剪贴板
" 真正需要剪切时使用 <Leader>d/c/x

" [Normal Mode] 删除操作映射到黑洞寄存器
nnoremap d "_d
nnoremap dd "_dd
nnoremap D "_D
nnoremap c "_c
nnoremap cc "_cc
nnoremap C "_C
nnoremap x "_x
nnoremap X "_X
nnoremap s "_s
nnoremap S "_S

" [Visual Mode] 删除操作映射到黑洞寄存器
vnoremap d "_d
vnoremap c "_c
vnoremap x "_x
vnoremap X "_X
vnoremap s "_s

" [需要剪切时] 使用 <Leader> + 操作符，真正放入剪贴板
nnoremap <Leader>d "+d
nnoremap <Leader>dd "+dd
nnoremap <Leader>D "+D
nnoremap <Leader>c "+c
nnoremap <Leader>cc "+cc
nnoremap <Leader>C "+C
nnoremap <Leader>x "+x
nnoremap <Leader>X "+X

vnoremap <Leader>d "+d
vnoremap <Leader>c "+c
vnoremap <Leader>x "+x

" [粘贴] 从系统剪贴板粘贴 (可选，因为 clipboard=unnamed 已启用)
nnoremap <Leader>p "+p
nnoremap <Leader>P "+P
vnoremap <Leader>p "+p
vnoremap <Leader>P "+P

" ============================================================================
" 4. 窗口与标签页导航 (Window & Tab Navigation)
" ============================================================================
" 窗口切换: 使用 Ctrl + h/j/k/l 代替 Ctrl-w + 方向
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" 标签页切换: 使用大写 H/L 左右切换文件
nnoremap H gT
nnoremap L gt

" ============================================================================
" 5. IDE 深度集成 (IDE Actions)
" ============================================================================
" 把 IDE 的强大功能映射到 Vim 快捷键

" [重构 & 调试]
nmap <Leader>r <Action>(RenameElement)          " 重命名 (Shift+F6)
nmap <Leader>b <Action>(ToggleLineBreakpoint)   " 打断点

" [项目导航]
nmap <Leader>f <Action>(SelectInProjectView)    " 定位当前文件
nmap <Leader>e <Action>(ActivateProjectToolWindow) " 显示/隐藏侧边栏

" [代码跳转]
nmap gd <Action>(GotoDeclaration)               " 跳转定义
nmap gr <Action>(FindUsages)                    " 查找引用 (Alt+F7)
nmap gi <Action>(GotoImplementation)            " 跳转实现

" ============================================================================
" 6. EasyMotion 高级配置 (The Flash)
" ============================================================================
" 使用 <Space> 作为 EasyMotion 的专属 Leader，不占用全局 Leader
let g:EasyMotion_leader_key = '<Space>'
let g:EasyMotion_keys = 'asdfghjklqwertyuiopzxcvbnm'
let g:EasyMotion_do_mapping = 0 " 禁用默认繁杂映射

" 映射辅助函数
function! s:EasyMotionMap(key, plug)
  execute 'nmap' a:key '<Plug>(easymotion-' . a:plug . ')'
  execute 'vmap' a:key '<Plug>(easymotion-' . a:plug . ')'
  execute 'omap' a:key '<Plug>(easymotion-' . a:plug . ')'
endfunction

" 核心跳转映射
call s:EasyMotionMap('<Space>s', 's')      " <Space>s + 字符 -> 全屏字符跳转
call s:EasyMotionMap('<Space>w', 'bd-w')   " <Space>w -> 全屏单词跳转
call s:EasyMotionMap('<Space>l', 'bd-jk')  " <Space>l -> 全屏行跳转
